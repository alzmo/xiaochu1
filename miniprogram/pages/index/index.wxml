<view class="page">
  <view class="header card">
    <view class="title">叠层矿格</view>
    <view>关卡：{{level}}</view>
    <view>状态：{{statusLabel}}</view>
    <view class="tips">规则：点击最上层方格，自动同色归仓，5 格暂存满则失败</view>
  </view>

  <view class="canvas card">
    <view
      wx:for="{{renderBlocks}}"
      wx:key="id"
      wx:if="{{!item.removed}}"
      class="block {{item.clickable ? 'clickable' : 'blocked'}} color-{{item.color}}"
      style="left: {{item.left}}rpx; top: {{item.top}}rpx; z-index: {{item.z}}"
      data-id="{{item.id}}"
      bindtap="onTapBlock"
    >
      <text>{{item.layer}}</text>
    </view>
  </view>

  <view class="panel card">
    <view class="panel-title">暂存槽（{{stashCount}} / 5）</view>
    <view class="stash-row">
      <view wx:for="{{stashSlots}}" wx:key="index" class="stash-slot color-{{item.color}}">
        <text wx:if="{{item}}">{{item.color}}</text>
      </view>
    </view>
  </view>

  <view class="panel card">
    <view class="panel-title">颜色收纳框</view>
    <view class="bins-row">
      <view wx:for="{{bins}}" wx:key="index" class="bin color-{{item.color}}">
        <view class="bin-color">{{item.color}}</view>
        <view>{{item.items.length}} / 3</view>
      </view>
    </view>
  </view>

  <view class="actions">
    <button size="mini" bindtap="restartLevel">重开本关</button>
    <button size="mini" type="primary" bindtap="nextLevel">下一关</button>
  </view>
</view>
